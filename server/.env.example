# Optional: enable spoken narration that works on TV browsers (Hisense, etc.)
# Leave unset to fall back to the browser's built-in voice.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional overrides:
# Pick any voice ID from https://elevenlabs.io/app/voice-library (Voice → ID)
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
# eleven_turbo_v2_5 = fast & cheap; eleven_multilingual_v2 = higher quality
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
