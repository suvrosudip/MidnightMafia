# ----- Narration voice (optional) -----
# Spoken narration that works on TV browsers (Hisense, etc.). Leave all unset to
# fall back to the display browser's built-in voice.

# RECOMMENDED HERE: ElevenLabs.
# Get an API key at elevenlabs.io (Profile -> API Keys) and paste it below.
# Leave GOOGLE_TTS_API_KEY empty so ElevenLabs is the active provider.
ELEVENLABS_API_KEY=

# Narrator voice (default = "Lily", a British female narrator).
# Other female premade voices you can drop in:
#   Rachel    (calm American)      21m00Tcm4TlvDq8ikWAM
#   Sarah     (soft American news) EXAVITQu4vr4xnSDxMaL
#   Charlotte (sophisticated)      XB0fDUnXU5powFXDhCwa
#   Matilda   (warm American)      XrExE9yKIg1WjnnlVkGX
# Or copy any voice ID from elevenlabs.io Voice Library.
ELEVENLABS_VOICE_ID=pFZP5JQG7iQjIQuC4Bku
# eleven_turbo_v2_5 = fast & credit-efficient; eleven_multilingual_v2 = higher quality
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# ALTERNATIVE PROVIDER: Google Cloud TTS (used only if its key is set; takes priority).
GOOGLE_TTS_API_KEY=
GOOGLE_TTS_VOICE=en-GB-Wavenet-D
GOOGLE_TTS_LANG=en-GB
GOOGLE_TTS_RATE=0.92
GOOGLE_TTS_PITCH=-2.0
